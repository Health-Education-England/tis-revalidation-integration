{
  "containerDefinitions": [
    {
      "name": "tis-revalidation-integration",
      "image": "430723991443.dkr.ecr.eu-west-2.amazonaws.com/tis-revalidation-integration:latest",
      "portMappings": [
        {
          "containerPort": 8088
        }
      ],
      "environment": [
        {
          "name": "TITLE",
          "value": "tis-revalidation-integration"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-west-2"
        },
        {
          "name": "SENTRY_ENVIRONMENT",
          "value": "${environment}"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "awslogs-${environment}-tis-revalidation-integration",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "awslogs-tis-revalidation-integration"
        }
      },
      "secrets": [
        {
          "name": "CONCERN_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "CONCERN_PORT",
          "valueFrom": "tis-revalidation-concerns-${environment}-port"
        },
        {
          "name": "CORE_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "CORE_PORT",
          "valueFrom": "tis-revalidation-core-${environment}-port"
        },
        {
          "name": "GMC_CLIENT_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "GMC_CLIENT_PORT",
          "valueFrom": "tis-revalidation-gmc-client-${environment}-port"
        },
        {
          "name": "RECOMMENDATION_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "RECOMMENDATION_PORT",
          "valueFrom": "tis-revalidation-recommendation-${environment}-port"
        },
        {
          "name": "CONNECTION_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "CONNECTION_PORT",
          "valueFrom": "tis-revalidation-connection-${environment}-port"
        },
        {
          "name": "TCS_HOST",
          "valueFrom": "tis-tcs-${environment}-host"
        },
        {
          "name": "TCS_PORT",
          "valueFrom": "tis-tcs-${environment}-port"
        },
        {
          "name": "COMMON_UPLOAD_HOST",
          "valueFrom": "tis-revalidation-${environment}-private-lb-url"
        },
        {
          "name": "COMMON_UPLOAD_PORT",
          "valueFrom": "tis-revalidation-common-upload-${environment}-port"
        },
        {
          "name": "PROFILE_HOST",
          "valueFrom": "tis-profile-${environment}-host"
        },
        {
          "name": "PROFILE_PORT",
          "valueFrom": "tis-profile-${environment}-port"
        },
        {
          "name": "REFERENCE_HOST",
          "valueFrom": "tis-reference-${environment}-host"
        },
        {
          "name": "REFERENCE_PORT",
          "valueFrom": "tis-reference-${environment}-port"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "tis-revalidation-integration-sentry-dsn"
        },
        {
          "name": "KC_REALM",
          "valueFrom": "tis-revalidation-kc-${environment}-realm"
        },
        {
          "name": "KC_CLIENT_ID",
          "valueFrom": "tis-revalidation-kc-${environment}-client-id"
        },
        {
          "name": "KC_SERVER_URL",
          "valueFrom": "tis-revalidation-kc-${environment}-server-url"
        },
        {
          "name": "KC_USERNAME",
          "valueFrom": "tis-revalidation-kc-${environment}-username"
        },
        {
          "name": "KC_PASSWORD",
          "valueFrom": "tis-revalidation-kc-${environment}-password"
        },
        {
          "name": "RVADMIN_ROLE_NAMES",
          "valueFrom": "/tis/revalidation/${environment}/rvadmin/roles"
        },
        {
          "name": "RABBITMQ_HOST",
          "valueFrom": "tis-revalidation-rabbit-${environment}-host"
        },
        {
          "name": "RABBITMQ_PASSWORD",
          "valueFrom": "tis-revalidation-rabbit-${environment}-password"
        },
        {
          "name": "RABBITMQ_PORT",
          "valueFrom": "tis-revalidation-rabbit-${environment}-port"
        },
        {
          "name": "RABBITMQ_USERNAME",
          "valueFrom": "tis-revalidation-rabbit-${environment}-username"
        },
        {
          "name": "RABBITMQ_USE_SSL",
          "valueFrom": "tis-revalidation-rabbit-${environment}-use-ssl"
        },
        {
          "name": "REVAL_RABBIT_EXCHANGE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/exchange"
        },
        {
          "name": "REVAL_RABBIT_RECOMMENDATION_SYNC_START_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/recommendation/syncstart"
        },
        {
          "name": "REVAL_RABBIT_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/connection/update"
        },
        {
          "name": "REVAL_RABBIT_SYNC_START_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/connection/syncstart"
        },
        {
          "name": "REVAL_RABBIT_SYNC_DATA_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/connection/syncdata"
        },
        {
          "name": "REVAL_RABBIT_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/connection/update"
        },
        {
          "name": "REVAL_RABBIT_SYNCSTART_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/connection/syncstart"
        },
        {
          "name": "REVAL_RABBIT_RECOMMENDATION_SYNCSTART_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/recommendation/syncstart"
        },
        {
          "name": "REVAL_RABBIT_SYNCDATA_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/connection/syncdata"
        },
        {
          "name": "ES_URLS",
          "valueFrom": "es7-4${environment}-url"
        },
        {
          "name": "SQS_CDC_DOCTOR_QUEUE",
          "valueFrom": "/tis/revalidation/documentdb-cdc/${environment}/queue-url/doctorsfordb"
        },
        {
          "name": "SQS_CDC_RECOMMENDATION_QUEUE",
          "valueFrom": "/tis/revalidation/documentdb-cdc/${environment}/queue-url/recommendation"
        },
        {
          "name": "SQS_CDC_CONNECTION_QUEUE",
          "valueFrom": "/tis/revalidation/documentdb-cdc/${environment}/queue-url/connectionlogs"
        },
        {
          "name": "SQS_CDC_HIDDEN_DISCREPANCY_QUEUE",
          "valueFrom": "/tis/revalidation/documentdb-cdc/${environment}/queue-url/hiddendiscrepancy"
        },
        {
          "name": "ESSYNC_GMC_DATA_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/revalidationsummary/essync/integration"
        },
        {
          "name": "CONNECTION_LOG_ESSYNCDATA_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/connectionlog/essyncdata/integration"
        },
        {
          "name": "CONNECTION_LOG_ESSYNCSTART_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/connectionlog/essyncstart"
        },
        {
          "name": "HIDDEN_DISCREPANCY_ESSYNCDATA_QUEUE",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/queue/hiddendiscrepancy/essyncdata/integration"
        },
        {
          "name": "HIDDEN_DISCREPANCY_ESSYNCSTART_ROUTING_KEY",
          "valueFrom": "/tis/revalidation/${environment}/rabbit/routingkey/hiddendiscrepancy/essyncstart"
        }
      ]
    }
  ],
  "executionRoleArn": "ecsTaskExecutionRole",
  "taskRoleArn": "tis-reval-integration-ecs-taskrole-${environment}",
  "family": "tis-revalidation-integration-${environment}",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "1024"
}
